{
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "always",
    "overrides": [
        {
            "files": "*",
            "options": {
                "tabWidth": 4
            }
        }
    ]
}
